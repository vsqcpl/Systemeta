datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  // Custom VSQC Fields
  passwordHash       String
  role               String    // e.g. super_admin, project_manager, senior_consultant, consultant, accounts, client_contact
  status             String    @default("active") // "active", "inactive", "Invited"
  mfa                Boolean   @default(false)
  lastLoginAt        DateTime?
  mustChangePassword Boolean   @default(true)
  
  // Relations
  clientId           String?
  reporteeOfId       String?
  reporteeOf         User?     @relation("ReportingRelationship", fields: [reporteeOfId], references: [id])
  reportees          User[]    @relation("ReportingRelationship")
  
  projects           ProjectAssignment[]
  tasks              Task[]
  taskAssignments    TaskAssignment[]
  timesheets         Timesheet[]
  punchSessions      PunchSession[]
  leaveRequests      LeaveRequest[]
  expenses           Expense[]
  activities         Activity[]
  notifications      Notification[]

  sessions           Session[]
  accounts           Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Project {
  id          String              @id @default(uuid())
  code        String?             @unique
  name        String
  client      String
  status      String              // e.g. active, planning, completed
  health      String              // e.g. on-track, at-risk, delayed
  progress    Int                 @default(0)
  budget      Float
  spent       Float               @default(0)
  dueDate     String
  managerName String
  priority    String              // e.g. critical, high, medium, low
  type        String              // e.g. Transformation, ERP, Security, etc.
  
  users       ProjectAssignment[]
  tasks       Task[]
  milestones  Milestone[]
  expenses    Expense[]
  invoices    Invoice[]
}

model ProjectAssignment {
  userId    String
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model Task {
  id                   String        @id @default(uuid())
  title                String
  projectId            String
  project              Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId           String
  assignee             User          @relation(fields: [assigneeId], references: [id], onDelete: Cascade)
  priority             String        // e.g. critical, high, medium, low
  dueDate              String
  estimate             Float
  progress             Int           @default(0)
  status               String        // e.g. todo, inprogress, review, done
  tags                 String
  isMilestone          Boolean       @default(false)
  actualCompletionDate String?
  comments             TaskComment[]
  subtasks             Subtask[]
  assignees            TaskAssignment[]

  @@index([projectId])
  @@index([assigneeId])
}

model TaskAssignment {
  taskId String
  userId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model Subtask {
  id          String   @id @default(uuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  dueDate     String
  description String?
  isMilestone Boolean  @default(false)
  status      String   @default("Not Started") // e.g. Not Started, In Progress, Completed

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userName  String
  avatar    String
  color     String
  role      String
  text      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Milestone {
  id        String    @id @default(uuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  date      String
  status    String    // e.g. upcoming, at-risk, delayed, completed
  amount    Float

  @@index([projectId])
}

model Timesheet {
  id           String           @id @default(uuid())
  consultantId String
  consultant   User             @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  week         String           // YYYY-MM-DD
  entries      TimesheetEntry[]

  @@unique([consultantId, week])
  @@index([consultantId])
  @@index([week])
}

model TimesheetEntry {
  id          String    @id @default(uuid())
  timesheetId String
  timesheet   Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  day         Int       // 0 to 6
  projectId   String
  task        String
  hours       Float
  billable    Boolean   @default(true)

  @@index([projectId])
  @@index([timesheetId])
}

model PunchSession {
  id           String    @id @default(uuid())
  consultantId String
  consultant   User      @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  punchIn      DateTime
  punchOut     DateTime?
  project      String?
  task         String?
  location     String?
  workNotes    String?
  date         String    // YYYY-MM-DD
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model LeaveRequest {
  id           String   @id @default(uuid())
  consultantId String
  consultant   User     @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  type         String   // e.g. Annual Leave, Sick Leave, Study Leave
  start        String
  end          String
  days         Int
  status       String   @default("pending") // e.g. pending, approved, rejected
  reason       String
}

model Expense {
  id           String   @id @default(uuid())
  consultantId String
  consultant   User     @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category     String   // e.g. Travel, Accommodation, Meals, Transport, Other
  description  String
  amount       Float
  currency     String
  date         String
  status       String   @default("pending") // e.g. pending, approved, rejected
  receipt      String?
  modeOfTransport    String?
  fromLocation       String?
  toLocation         String?
  calculatedDistance Float?
}

model Invoice {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client    String
  amount    Float
  status    String   // e.g. draft, issued, partially_paid, paid, overdue, cancelled
  issued    String
  due       String?
  paid      String?

  payments  Payment[]
}

model Payment {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount          Float
  date            String
  method          String
  referenceNumber String?
  transactionId   String?
  remarks         String?
  proofUrl        String?
  recordedBy      String
  recordedAt      DateTime @default(now())
}

model AIInsight {
  id          String   @id @default(uuid())
  type        String   // e.g. risk, resource, revenue, prediction, performance
  severity    String   // e.g. high, medium, low, info
  title       String
  description String
  action      String
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  subject   String
  projectId String?
  type      String   // e.g. task, file, risk, timesheet, comment, invoice, leave, ai
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // e.g. alert, approval, risk, info, success
  title     String
  message   String
  createdAt String
  read      Boolean  @default(false)
  category  String?  // e.g. project, timesheet, general
}

model AuditLog {
  id        String   @id @default(uuid())
  timestamp String
  userEmail String
  action    String
  resource  String
  detail    String
  ip        String
}

model PermissionOverride {
  id            String   @id @default(uuid())
  userId        String
  permissionKey String
  granted       Boolean
  grantedBy     String
  reason        String
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Client Manager CRM Models ───────────────────────────────────────────────

model Client {
  id           String        @id @default(uuid())
  name         String
  industry     String?
  website      String?
  address      String?
  status       String        @default("active")  // active, inactive, prospect
  tier         String        @default("standard") // standard, premium, enterprise
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  contacts     Contact[]
  calls        Call[]
  meetings     Meeting[]
  followUps    FollowUp[]
  requirements Requirement[]
  opportunities Opportunity[]
}

model Contact {
  id         String   @id @default(uuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  email      String?
  phone      String?
  role       String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Call {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conductedBy String
  subject     String
  notes       String?
  outcome     String?  // positive, neutral, negative, follow-up-needed
  duration    Int?     // minutes
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Meeting {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizedBy String
  title       String
  agenda      String?
  notes       String?
  platform    String?  // teams, meet, in-person, zoom
  meetLink    String?
  status      String   @default("scheduled") // scheduled, completed, cancelled
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FollowUp {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo  String
  description String
  dueDate     DateTime
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("open")   // open, in-progress, done, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Requirement {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String?  // staffing, consulting, technology, training, other
  priority    String   @default("medium")
  status      String   @default("open")  // open, scoping, proposal-sent, won, lost
  budget      Float?
  raisedBy    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Opportunity {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  value        Float?
  stage        String   @default("prospect") // prospect, qualified, proposal, negotiation, won, lost
  probability  Int      @default(0)           // 0-100
  expectedClose DateTime?
  ownedBy      String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Escalation {
  id          String   @id @default(uuid())
  clientId    String
  title       String
  description String
  severity    String   @default("medium") // low, medium, high, critical
  status      String   @default("open")   // open, in-progress, resolved, closed
  raisedBy    String
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
